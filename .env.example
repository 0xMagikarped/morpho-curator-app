# WalletConnect project ID (get one at https://cloud.walletconnect.com/)
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: Sentry DSN for error tracking
VITE_SENTRY_DSN=

# Server-side Alchemy key for the /api/rpc proxy. NOT prefixed VITE_, so it is
# never bundled into the client — the proxy (api/rpc/[chainId].js + the Vite
# dev middleware) injects it server-side. Set the same value in the Vercel
# project's Environment Variables for production. Covers ETH, Base, BNB, SEI,
# and Pharos; XDC stays on its public RPC.
ALCHEMY_API_KEY=

# Optional: custom (non-keyed) RPC URLs. Keyed URLs are rejected by env.ts to
# avoid leaking secrets in the public bundle — use ALCHEMY_API_KEY instead.
VITE_ETH_RPC_URL=
VITE_BASE_RPC_URL=
VITE_SEI_RPC_URL=
VITE_BNB_RPC_URL=
VITE_PHAROS_RPC_URL=https://rpc.pharos.xyz
VITE_XDC_RPC_URL=
VITE_AVALANCHE_RPC_URL=
